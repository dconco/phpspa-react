APP_ENV=dev

# Dev server origin for Vite modules and HMR.
VITE_DEV_ORIGIN=http://localhost:5173

# Production build output and manifest paths.
FRONTEND_DIST_DIR=resources/dist
FRONTEND_MANIFEST_FILE=resources/dist/.vite/manifest.json

# Production public base for frontend assets.
# Use / for root deploy, /myapp/ for subfolder, or full CDN URL.
FRONTEND_PUBLIC_BASE_URL=/
